AZ_LOCATION=westeurope
AZ_RESOURCE_GROUP=rg-aks-monitoring-dev
AKS_NAME=aks-monitoring-dev
AKS_K8S_VERSION=
AKS_NODE_COUNT=2
AKS_NODE_VM_SIZE=Standard_D4s_v5
AKS_NODE_OSDISK_SIZE=128
AKS_NETWORK_PLUGIN=azure
AKS_LOAD_BALANCER_SKU=standard
MONITORING_NAMESPACE=monitoring
INGRESS_CLASS_NAME=nginx
GRAFANA_HOST=grafana.example.com
PROMETHEUS_HOST=prometheus.example.com
GRAFANA_ADMIN_PASSWORD=ChangeMe-Use-A-Secret-Manager
GRAFANA_STORAGE_SIZE=10Gi
PROMETHEUS_STORAGE_SIZE=30Gi
ALERTMANAGER_STORAGE_SIZE=5Gi
